# Server
PORT=5000
NODE_ENV=development

# Database (required)
# Use your MongoDB Atlas connection string here. Get it from:
# Atlas dashboard -> Database -> Connect -> Drivers -> Node.js
# Both names are supported by config/db.js; MONGO_URI takes priority if both are set.
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/<database_name>?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://<db_user>:<db_password>@<cluster-host>/<database_name>?retryWrites=true&w=majority

# Auth (required)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend
CLIENT_URL=http://localhost:5173

# Google Gemini (left empty intentionally - not integrated yet)
GEMINI_API_KEY=

